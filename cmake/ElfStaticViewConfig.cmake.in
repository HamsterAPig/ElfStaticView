@PACKAGE_INIT@

if(NOT TARGET libdwarf::dwarf)
  add_library(libdwarf::dwarf STATIC IMPORTED)
  set_target_properties(
    libdwarf::dwarf
    PROPERTIES
      IMPORTED_LOCATION "${PACKAGE_PREFIX_DIR}/lib/@CMAKE_STATIC_LIBRARY_PREFIX@dwarf@CMAKE_STATIC_LIBRARY_SUFFIX@"
      INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
  )
endif()

include("${CMAKE_CURRENT_LIST_DIR}/ElfStaticViewTargets.cmake")

if(NOT TARGET elf_static_view::core AND TARGET elf_static_view::elf_static_view_core)
  add_library(elf_static_view::core ALIAS elf_static_view::elf_static_view_core)
endif()
